@model IEnumerable<SistemaGestionFerreteria.Models.Entities.Categoria>

@{
    ViewData["Title"] = "Categorias";
}

<h1 class="mb-4">Categorias</h1>

<a asp-action="Create" class="btn btn-primary mb-3">
    Nueva Categoria
</a>

<table id="tablaCategorias" class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Descripcion</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var categoria in Model)
        {
            <tr>
                <td>@categoria.Nombre</td>
                <td>@categoria.Descripcion</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@categoria.Id" class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <a asp-action="Delete" asp-route-id="@categoria.Id" class="btn btn-danger btn-sm">
                        Eliminar
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {

    <script>

        new DataTable('#tablaCategorias');

    </script>

}