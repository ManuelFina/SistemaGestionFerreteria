@model SistemaGestionFerreteria.Models.Entities.Producto

@{
    ViewData["Title"] = "Eliminar Producto";
}

<h1 class="mb-4 text-danger">Eliminar Producto</h1>

<div class="alert alert-warning">
    ¿Estas seguro que deseas eliminar este producto?
</div>

<div class="card shadow-sm">
    <div class="card-body">

        <p>
            <strong>Nombre:</strong>
            @Model.Nombre
        </p>

        <p>
            <strong>Precio:</strong>
            $@Model.Precio
        </p>

        <p>
            <strong>Stock:</strong>
            @Model.Stock
        </p>

        <p>
            <strong>Categoria:</strong>
            @Model.Categoria?.Nombre
        </p>

        <p>
            <strong>Proveedor:</strong>
            @Model.Proveedor?.Nombre
        </p>

    </div>
</div>

<form asp-action="Delete" class="mt-3">

    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Eliminar
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancelar
    </a>

</form>