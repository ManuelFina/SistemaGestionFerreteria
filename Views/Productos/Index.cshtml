@model IEnumerable<SistemaGestionFerreteria.Models.Entities.Producto>

@{
    ViewData["Title"] = "Productos";
}

<h1 class="mb-4">Productos</h1>

<a asp-action="Create" class="btn btn-primary mb-3">
    Nuevo Producto
</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Categoria</th>
            <th>Proveedor</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var producto in Model)
        {
            <tr>
                <td>@producto.Nombre</td>
                <td>@producto.Precio</td>
                <td>@producto.Stock</td>
                <td>@producto.Categoria?.Nombre</td>
                <td>@producto.Proveedor?.Nombre</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@producto.Id" class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <a asp-action="Delete" asp-route-id="@producto.Id" class="btn btn-danger btn-sm">
                        Eliminar
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>