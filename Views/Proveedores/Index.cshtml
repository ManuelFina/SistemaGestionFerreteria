@model IEnumerable<SistemaGestionFerreteria.Models.Entities.Proveedor>

@{
    ViewData["Title"] = "Proveedores";
}

<h1 class="mb-4">Proveedores</h1>

<a asp-action="Create" class="btn btn-primary mb-3">
    Nuevo Proveedor
</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Telefono</th>
            <th>Email</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var proveedor in Model)
        {
            <tr>
                <td>@proveedor.Nombre</td>
                <td>@proveedor.Telefono</td>
                <td>@proveedor.Email</td>
                <td>
                    <a asp-action="Edit"
                       asp-route-id="@proveedor.Id"
                       class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@proveedor.Id"
                       class="btn btn-danger btn-sm">
                        Eliminar
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>