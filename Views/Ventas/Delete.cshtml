@model SistemaGestionFerreteria.Models.Entities.Venta

@{
    ViewData["Title"] = "Eliminar Venta";
}

<h1 class="mb-4 text-danger">Eliminar Venta</h1>

<div class="alert alert-warning">
    ¿Estas seguro que deseas eliminar esta venta?
</div>

<div class="card shadow-sm">
    <div class="card-body">

        <p>
            <strong>Cliente:</strong>
            @Model.Cliente?.Nombre
        </p>

        <p>
            <strong>Fecha:</strong>
            @Model.Fecha.ToShortDateString()
        </p>

        <p>
            <strong>Total:</strong>
            $@Model.Total
        </p>

    </div>
</div>

<form asp-action="Delete" class="mt-3">

    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Eliminar
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancelar
    </a>

</form>